rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isAuthenticated() &&
        ((userDoc != null && userDoc.data.role == 'admin') ||
          (request.auth.token.email == "dincsihhitesisat@gmail.com" && request.auth.token.email_verified == true));
    }
    function hasRequiredFields(fields) { return request.resource.data.keys().hasAll(fields); }
    function hasOnlyAllowedFields(fields) { return request.resource.data.keys().hasOnly(fields); }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidArticle(data) {
      return hasOnlyAllowedFields(['title', 'summary', 'content', 'author', 'category', 'createdAt', 'imageUrl', 'isActive', 'displayOptions']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.summary is string && data.summary.size() < 2000 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 100000 &&
             data.author is string &&
             data.category is string &&
             data.createdAt is string &&
             data.imageUrl is string &&
             data.isActive is bool &&
             data.displayOptions is map;
    }

    function isValidCategory(data) {
      return hasOnlyAllowedFields(['name', 'showInMenu', 'showOnHomepage', 'color']) && 
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.showInMenu is bool &&
             (!('showOnHomepage' in data) || data.showOnHomepage is bool) &&
             data.color is string && data.color.size() > 0 && data.color.size() < 20;
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['name', 'email', 'role']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    function isValidAd(data) {
      return hasOnlyAllowedFields(['type', 'imageUrl', 'adCode', 'link']) &&
             data.type in ['image', 'code'] &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 100000)) &&
             (!('adCode' in data) || (data.adCode is string && data.adCode.size() < 100000)) &&
             (!('link' in data) || (data.link is string && data.link.size() < 1000));
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /articles/{articleId} {
      allow read: if true;
      allow create: if isAdmin() && isValidArticle(request.resource.data);
      allow update: if isAdmin() && isValidArticle(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCategory(request.resource.data);
      allow update: if isAdmin() && isValidCategory(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() && isValidUser(request.resource.data);
      allow update: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /config/site {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sidebarAds/{adId} {
      allow read: if true;
      allow write: if isAdmin() && isValidAd(request.resource.data);
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
